# Port the Hono service listens on.
PORT=4001

# Branding shown in /.well-known/atlas.json.
PLATFORM_NAME="ATLAS Demo Platform"
PLATFORM_URL=http://localhost:4001
# Optional did:web identifier for receipt verification.
# PLATFORM_DID=did:web:demo.example.com

# EVM address that receives USDC for x402 settlements. Should be the
# FeeRouter proxy address on the chosen chain in production. The default
# below is a burn address — replace before broadcasting on a real chain.
ORGANIZER_ADDRESS=0x000000000000000000000000000000000000dEaD

# Comma-separated CHAIN_SPECS keys (see packages/server-sdk/src/chain-specs.ts).
# Defaults to base_usdc,optimism_usdc,arbitrum_usdc if unset.
ACCEPTED_CHAINS=base_usdc,optimism_usdc,arbitrum_usdc

# Whether the platform also accepts Stripe SPT (fiat). Requires STRIPE_SECRET_KEY.
ACCEPT_STRIPE=true
# Stripe secret key. Required when ACCEPT_STRIPE=true.
STRIPE_SECRET_KEY=sk_test_...
