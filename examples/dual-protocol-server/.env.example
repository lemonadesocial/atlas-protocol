# Port the Hono service listens on.
PORT=4001

# Branding shown in /.well-known/atlas.json.
PLATFORM_NAME="ATLAS Demo Platform"
PLATFORM_URL=http://localhost:4001
# Optional did:web identifier for receipt verification.
# PLATFORM_DID=did:web:demo.example.com

# EVM address that receives USDC for x402 settlements. Should be the
# FeeRouter proxy address on the chosen chain in production. The default
# below is a burn address — replace before broadcasting on a real chain.
ORGANIZER_ADDRESS=0x000000000000000000000000000000000000dEaD

# Comma-separated CHAIN_SPECS keys (see packages/server-sdk/src/chain-specs.ts).
# Defaults to base_usdc,optimism_usdc,arbitrum_usdc if unset.
ACCEPTED_CHAINS=base_usdc,optimism_usdc,arbitrum_usdc

# Whether the platform also accepts Stripe SPT (fiat). Requires STRIPE_SECRET_KEY.
ACCEPT_STRIPE=true
# Stripe secret key. Required when ACCEPT_STRIPE=true.
STRIPE_SECRET_KEY=sk_test_...

# ---------------------------------------------------------------------------
# Optional integration env vars
#
# Each block below is independently optional. When unset, the example logs
# a warning and skips the corresponding step rather than failing — so the
# example remains runnable locally without on-chain or pinning credentials.
# ---------------------------------------------------------------------------

# AtlasTicket (ERC-721) proxy address on the settlement chain. Pull from
# `deployments.json` once the contract has been deployed on your chain.
# Required to mint a ticket NFT after a successful purchase.
# ATLAS_TICKET_ADDRESS=0x...

# RewardLedger (organizer / attendee / referral accrual) proxy address on
# the settlement chain. Pull from `deployments.json` once the contract has
# been deployed. Required to record an organizer reward after settlement.
# REWARD_LEDGER_ADDRESS=0x...

# Server-side wallet that signs the mint + recordReward txs. MUST hold the
# MINTER role on the AtlasTicket contract and the RECORDER role on the
# RewardLedger contract. Hex-encoded private key, 0x-prefixed.
# WALLET_PRIVATE_KEY=0x...

# RPC URL for the settlement chain. Used by the wallet client.
# RPC_URL=https://mainnet.base.org

# Display name for the settlement chain — surfaces in the receipt's
# `settlement.chain` field. Defaults to "base".
# SETTLEMENT_CHAIN_NAME=base

# Pinata JWT for receipt pinning. When set, the issued W3C VC receipt is
# canonicalized and pinned to IPFS in the same call as `generateReceipt`,
# and the returned `cid` is included in the response body.
# PINATA_JWT=eyJhbGciOi...

# Web3.Storage credentials (alternative pinner). Only used when PINATA_JWT
# is unset. Both variables must be present.
# WEB3_STORAGE_TOKEN=...
# WEB3_STORAGE_SPACE_DID=did:key:...
