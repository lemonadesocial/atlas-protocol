# Target purchase endpoint. Defaults to the dual-protocol-server example.
TARGET_URL=http://localhost:4001/atlas/v1/events/evt_jazz_brooklyn_001/purchase

# Ticket selection passed in the request body.
TICKET_TYPE_ID=tt_ga_001
QUANTITY=1

# ---------------------------------------------------------------------------
# x402 (on-chain USDC) — configure these to enable the x402 rail.
# ---------------------------------------------------------------------------
# Funded wallet that signs the USDC transfer.
# AGENT_PRIVATE_KEY=0x...
# Comma-separated EVM addresses we are willing to pay (the platform's
# FeeRouter / organizer wallet). If the 402 names a different recipient the
# helper aborts WITHOUT signing anything.
# ALLOWED_RECEIVERS=0x000000000000000000000000000000000000dEaD
# Comma-separated USDC contract addresses we accept. Chain-specific.
# Default below is Base Sepolia testnet USDC.
# ALLOWED_STABLECOINS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Per-request hard cap, in 6-decimal USDC micro-units. 100_000_000 = $100.
# MAX_AMOUNT_USDC_MICRO=100000000
# Optional chain selection. Supported: 8453 (base), 84532 (base-sepolia),
# 10 (optimism), 42161 (arbitrum). Defaults to 84532.
# CHAIN_ID=84532
# Optional RPC override.
# RPC_URL=https://sepolia.base.org

# ---------------------------------------------------------------------------
# stripe-mpp (Stripe SPT) — configure these to enable the Stripe rail.
# ---------------------------------------------------------------------------
# Stripe secret key (test mode is fine).
# STRIPE_SECRET_KEY=sk_test_...
# Comma-separated platform-side receivers (whatever the 402 carries as
# `recipient` for stripe_spt — usually a Stripe account id).
# ALLOWED_STRIPE_RECEIVERS=stripe:acct_atlas_demo
# Per-request hard cap in USD cents. 10000 = $100.
# MAX_AMOUNT_USD_CENTS=10000
# Stripe payment method id to charge. Defaults to the test Visa.
# STRIPE_PAYMENT_METHOD_ID=pm_card_visa
