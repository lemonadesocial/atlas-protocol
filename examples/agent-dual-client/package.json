{
  "name": "@atlasprotocol/example-agent-dual-client",
  "version": "0.1.0",
  "private": true,
  "description": "Reference example: an agent paying an HTTP 402 challenge with both rails — @atlasprotocol/mpp/x402 (on-chain USDC) and @atlasprotocol/mpp/stripe-mpp (Stripe SPT). Pairs with the dual-protocol-server example.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@atlasprotocol/mpp": "workspace:*",
    "stripe": "^22.1.0",
    "viem": "^2.48.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.3"
  }
}
