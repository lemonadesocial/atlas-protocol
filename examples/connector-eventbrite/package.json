{
  "name": "@atlas/connector-eventbrite-example",
  "version": "0.1.0",
  "private": true,
  "description": "Reference Eventbrite connector for the ATLAS Protocol. Demonstrates OAuth2 PKCE, REST pagination, and source-platform → ATLAS schema mapping.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "echo \"no lint configured\" && exit 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@atlas/connector-framework": "workspace:*",
    "@atlas/server-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0"
  }
