    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@atlasprotocol/connector-framework": "workspace:*",
    "@atlasprotocol/server-sdk": "workspace:*"
  },
  "devDependencies": {
