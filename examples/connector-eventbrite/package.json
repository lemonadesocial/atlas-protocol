{
  "name": "@atlasprotocol/connector-eventbrite-example",
  "version": "0.1.0",
  "private": true,
  "description": "Reference Eventbrite connector for the ATLAS Protocol. Demonstrates OAuth2 PKCE, REST pagination, and source-platform → ATLAS schema mapping.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
