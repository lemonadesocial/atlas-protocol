{
  "name": "@atlasprotocol/server-sdk",
  "version": "0.7.0",
  "description": "Server-side ATLAS Protocol primitives. Manifest generation, schema mapping, multi-chain payment verification. Framework-agnostic.",
  "license": "MIT",
  "homepage": "https://github.com/lemonadesocial/atlas-protocol/tree/main/packages/server-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonadesocial/atlas-protocol.git",
    "directory": "packages/server-sdk"
  },
  "keywords": [
    "atlas",
    "atlas-protocol",
    "server",
    "well-known",
    "x402",
    "usdc",
    "events"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-deployments.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@atlasprotocol/mpp": "workspace:^",
    "@atlasprotocol/types": "workspace:^",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "stripe": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "stripe": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "hono": "^4.6.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0"
  }
}
