{
  "name": "@atlasprotocol/types",
  "version": "0.2.0",
  "description": "Shared TypeScript type definitions for the ATLAS Protocol — events, ticket types, manifests, purchase challenges, W3C VC receipts, and IPFS pinner abstractions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonadesocial/atlas-protocol.git",
    "directory": "packages/types"
  },
  "keywords": [
    "atlas",
    "atlas-protocol",
    "types",
    "schemas"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
